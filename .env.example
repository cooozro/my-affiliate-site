# Copy to .env and fill in keys (never commit .env)

# Cover images — copy from GitHub repo Secrets (Settings → Secrets and variables → Actions)
# Local optional; GHA fetch-draft-covers workflow uses Secrets when you push drafts without covers.
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Serper.dev — B-type SERP benchmark (local replenish tests)
SERPER_API_KEY=

# GA4 — admin dashboard widget + local `npm run seo-audit:update`
# Same names as GitHub Actions Secrets / Vercel Environment Variables
GA4_PROPERTY_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
